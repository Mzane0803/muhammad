---
layout: null
permalink: /writings.json
---
[
{% assign published = site.writings | where: "published", true | sort: "date" | reverse %}
{% for w in published %}
  {
    "slug": {{ w.slug | jsonify }},
    "type": {{ w.type | jsonify }},
    "title": {{ w.title | jsonify }},
    "date": "{{ w.date | date: '%Y-%m-%d' }}",
    "read_time": {{ w.read_time | jsonify }},
    "description": {{ w.description | jsonify }},
    "dek": {{ w.dek | jsonify }},
    "tags": {{ w.tags | jsonify }},
    "body_html": {{ w.content | strip_newlines | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
