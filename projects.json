---
layout: null
permalink: /projects.json
---
[
{% assign published = site.projects | where: "published", true | sort: "order" %}
{% for p in published %}
  {
    "name": {{ p.name | jsonify }},
    "status": {{ p.status | jsonify }},
    "description": {{ p.description | jsonify }},
    "stack": {{ p.stack | jsonify }},
    "url": {{ p.url | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
