---
layout: null
permalink: /projects.json
---
[
{%- assign visible = site.projects | where_exp: "p", "p.published != false" | sort: "order" -%}
{%- for p in visible -%}
  {
    "name": {{ p.name | jsonify }},
    "status": {{ p.status | jsonify }},
    "description": {{ p.description | jsonify }},
    "stack": {{ p.stack | jsonify }},
    "url": {{ p.url | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
