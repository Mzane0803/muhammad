    "og_image": {{ site.data.site.seo.og_image | jsonify }}
  },
  "nav": {
    "home": {{ site.data.site.nav.home | jsonify }},
    "writing": {{ site.data.site.nav.writing | jsonify }},
    "projects": {{ site.data.site.nav.projects | jsonify }},
    "resume": {{ site.data.site.nav.resume | jsonify }},
    "about": {{ site.data.site.nav.about | jsonify }},
    "contact": {{ site.data.site.nav.contact | jsonify }}
  },
  "hero": {
    "tagline": {{ site.data.site.hero.tagline | jsonify }},
    "name": {{ site.data.site.hero.name | jsonify }},
    "description": {{ site.data.site.hero.description | jsonify }}
  },
  "domains": {{ site.data.site.domains | jsonify }},
