  "contact": {
    "blurb": {{ site.data.site.contact.blurb | jsonify }},
    "email": {{ site.data.site.contact.email | jsonify }},
    "linkedin": {{ site.data.site.contact.linkedin | jsonify }},
    "vsco": {{ site.data.site.contact.vsco | jsonify }},
    "instagram": {{ site.data.site.contact.instagram | jsonify }}
